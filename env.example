# Clé de signature du Smart Contract de Trésorerie (Polygon/GLCMatic)
GLOIRE_PRIVATE_KEY=votre_cle_privee_polygon_ici

# Secrets Marchands Telecom Tchad
AIRTEL_API_SECRET=votre_secret_marchand_airtel_tchad
MOOV_API_SECRET=votre_secret_marchand_moov_tchad

# Configuration des Nœuds Souverains
GLOIRE_RPC_URL=https://polygon-rpc.com
